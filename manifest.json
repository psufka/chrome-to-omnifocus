{
  "manifest_version": 3,
  "name": "Chrome to OmniFocus by Paul Sufka",
  "version": "1.1.0",
  "description": "A Chrome extension by Paul Sufka to save the current tab or selected text as a task in OmniFocus.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "background": {
    "service_worker": "chrome-to-omnifocus.js"
  },
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_popup": "popup.html",
    "default_title": "Save to OmniFocus"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
